shape Box<T> {
    items: [1]T,

    fun get(self: ref<Self>) -> Maybe<T> {
        return std.mem.get(self.items, 0)
    }
}

pub fun main() -> Void {
    let mut x = 1
    let y = 2
    let mut box: Box<ref<i32>> = Box { items: [&x] }
    let maybe = box.get()
    let current = maybe.value
    box.items = [&y]
    x = 2
}
