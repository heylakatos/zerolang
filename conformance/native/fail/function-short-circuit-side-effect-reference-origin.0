shape Holder {
    value: ref<i32>,
}

fun replaceValue(holder: mutref<Holder>, next: ref<i32>) -> Bool {
    holder.value = next
    return true
}

fun maybeReplace(flag: Bool, holder: mutref<Holder>, next: ref<i32>) -> Void {
    let ok = flag && replaceValue(holder, next)
}

pub fun main(flag: Bool) -> Void {
    let mut old = 1
    let next = 2
    let mut holder = Holder { value: &old }
    maybeReplace(flag, &mut holder, &next)
    old = 3
}
