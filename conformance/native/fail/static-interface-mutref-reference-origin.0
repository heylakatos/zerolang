interface Storer<T> {
    fun store(self: mutref<T>, next: ref<i32>) -> Void
}

shape Holder {
    value: ref<i32>,

    fun store(self: mutref<Self>, next: ref<i32>) -> Void {
        self.value = next
    }
}

fun through<T: Storer<T>>(holder: mutref<T>, next: ref<i32>) -> Void {
    T.store(holder, next)
}

pub fun main() -> Void {
    let mut old = 1
    let mut next = 2
    let mut holder = Holder { value: &old }
    through<Holder>(&mut holder, &next)
    next = 3
}
