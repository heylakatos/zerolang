shape Holder {
    value: ref<i32>,
}

fun replace(holder: mutref<Holder>, next: ref<i32>) -> Void {
    holder.value = next
}

pub fun main() -> Void {
    let mut old = 1
    let mut next = 2
    let mut other = 3
    let mut holder = Holder { value: &old }
    let selected = &mut holder
    if true {
        let mut holder = Holder { value: &other }
        replace(selected, &next)
    }
    old = 4
    next = 5
}
