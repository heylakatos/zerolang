shape Holder {
    value: ref<i32>,
}

fun replaceValue(holder: mutref<Holder>, next: ref<i32>) -> Bool {
    holder.value = next
    return true
}

pub fun main() -> Void {
    let mut old = 1
    let next = 2
    let mut holder = Holder { value: &old }
    let ok = false && replaceValue(&mut holder, &next)
    old = 3
}
