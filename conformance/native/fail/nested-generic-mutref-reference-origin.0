shape Cell<T> {
    value: ref<T>,
}

fun replace<T>(cell: mutref<Cell<T>>, next: ref<T>) -> Void {
    cell.value = next
}

fun wrapper<T>(cell: mutref<Cell<T>>, next: ref<T>) -> Void {
    replace<T>(cell, next)
}

pub fun main() -> Void {
    let mut old = 1
    let mut next = 2
    let mut cell: Cell<i32> = Cell { value: &old }
    wrapper<i32>(&mut cell, &next)
    next = 3
}
